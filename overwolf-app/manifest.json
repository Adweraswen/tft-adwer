{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "TFT Adwer Bridge",
    "version": "0.1.0",
    "minimum-overwolf-version": "0.199.0.15",
    "author": "Adweraswen",
    "icon": "icons/icon.png",
    "icon_gray": "icons/icon.png",
    "description": "TFT Adwer Overwolf GEP bridge"
  },
  "data": {
    "start_window": "MainWindow",
    "windows": {
      "MainWindow": {
        "file": "src/index.html",
        "transparent": false,
        "resizable": false,
        "show_in_taskbar": true,
        "size": {
          "width": 400,
          "height": 300
        }
      }
    },
    "extra-scripts": [
      "src/js/bridge.js"
    ],
    "game_targeting": {
      "game_ids": [21570, 215701],
      "initial_launch_events": [
        "game_info",
        "live_client_data",
        "me",
        "match_info",
        "roster",
        "store",
        "board",
        "bench",
        "carousel",
        "augments",
        "match_stats"
      ]
    }
  },
  "game_events": {
    "game_ids": [21570, 215701],
    "features": [
      "gep_internal",
      "game_info",
      "live_client_data",
      "me",
      "match_info",
      "roster",
      "store",
      "board",
      "bench",
      "carousel",
      "augments",
      "match_stats"
    ]
  },
  "permissions": [
    "GameInfo",
    "Streaming",
    "FileSystem",
    "LogFile",
    "Extensions",
    "Processes",
    "Notifications"
  ]
}
